# ─────────────────────────────────────────────
# BRD Genius - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-gpt4-deployment-name
AZURE_OPENAI_SPEECH_DEPLOYMENT=your-whisper-deployment-name

# ── AWS Bedrock (Chatbot) ─────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ── Microsoft Azure AD (OneDrive OAuth) ───────
AZURE_BOT_CLIENT_ID=your_azure_app_client_id
AZURE_BOT_CLIENT_SECRET=your_azure_app_client_secret
AZURE_BOT_TENANT_ID=your_azure_tenant_id

# ── Google Cloud (GCS + Firebase) ─────────────
# For local storage mode, point to your Firebase service account JSON:
GOOGLE_APPLICATION_CREDENTIALS=brd001-firebase-adminsdk-fbsvc-20e67bbc71.json
